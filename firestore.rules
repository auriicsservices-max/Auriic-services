rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'darshanwala894@gmail.com' || 
        request.auth.token.email == 'auriicsservices@gmail.com' ||
        getUserData().get('role', 'none') == 'admin'
      );
    }

    function isTeamMember() {
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && (
        isAdmin() || (user.role == 'recruiter' && user.get('isArchived', false) == false)
      );
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      function isValidUser(data) {
        return data.uid is string && 
               data.email is string && 
               data.role in ['admin', 'recruiter'];
      }

      allow create: if isSignedIn() && isValidUser(request.resource.data);
      allow update: if isSignedIn() && isValidUser(request.resource.data);
      allow delete: if isSignedIn();
    }

    // Invitations for pre-registration
    match /invitations/{email} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Candidate Collection Rules
    match /candidates/{candidateId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Activity Logs Collection Rules
    match /activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Chat Message Rules (Global)
    match /messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    // Direct Message Rules (DM)
    match /direct_messages/{messageId} {
      allow get, list: if isSignedIn() && (
        resource.data.get('participants', []).hasAny([request.auth.uid]) ||
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      
      // Users can only send messages where they are one of the participants
      allow create: if isSignedIn() && (
        request.resource.data.get('participants', []).hasAny([request.auth.uid]) ||
        request.resource.data.senderId == request.auth.uid
      );

      // Users can mark messages as read if they are the recipient
      allow update: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
      );
      
      allow delete: if isAdmin();
    }

    // Typing State Rules
    match /typing_states/{conversationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
